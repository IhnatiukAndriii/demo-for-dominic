# Supabase Konfiguration
# Diese Werte findest du in deinem Supabase-Projekt unter Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://deine-projekt-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key

# Optional: Für serverseitige Operationen mit erhöhten Rechten
# SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key

# App-URL (für Redirects nach der Authentifizierung)
NEXT_PUBLIC_APP_URL=http://localhost:3000
